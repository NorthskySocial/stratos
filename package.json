{
  "name": "stratos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Stratos - Private namespace service for ATProtocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/example/stratos.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "lint": "eslint test && pnpm -r run lint",
    "format": "prettier --write .",
    "test": "vitest",
    "codegen": "pnpm --filter stratos-service run codegen",
    "e2etest": "deno run -A test/scripts/run-all.ts",
    "e2etestdirect": "deno run -A test/scripts/run-all.ts --direct"
  },
  "devDependencies": {
    "@types/deno": "^2.5.0",
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@vitest/coverage-v8": "^4.0.18"
  }
}
