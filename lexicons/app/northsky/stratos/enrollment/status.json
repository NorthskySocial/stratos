{
  "lexicon": 1,
  "id": "app.northsky.stratos.enrollment.status",
  "defs": {
    "main": {
      "type": "query",
      "description": "Check enrollment status for a DID in this Stratos service.",
      "parameters": {
        "type": "params",
        "required": ["did"],
        "properties": {
          "did": {
            "type": "string",
            "format": "did",
            "description": "The DID to check enrollment for."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["did", "enrolled"],
          "properties": {
            "did": {
              "type": "string",
              "format": "did",
              "description": "The DID that was checked."
            },
            "enrolled": {
              "type": "boolean",
              "description": "Whether the DID is enrolled in this Stratos service."
            },
            "enrolledAt": {
              "type": "string",
              "format": "datetime",
              "description": "When the DID was enrolled, if enrolled."
            },
            "boundaries": {
              "type": "array",
              "description": "Authoritative boundaries assigned.",
              "items": {
                "type": "ref",
                "ref": "app.stratos.boundary.defs#Domain"
              }
            }
          }
        }
      }
    }
  }
}
