# Stratos service URL (required for enrollment when user is not yet enrolled)
VITE_STRATOS_URL=http://localhost:3100

# Stratos service DID (required for enrollment verification and PDS record discovery)
VITE_STRATOS_SERVICE_DID=did:web:localhost

# Optional AppView URL for merged public/private timeline views
# VITE_APPVIEW_URL=http://localhost:2584

# Optional handle resolver for browser OAuth sign-in
# VITE_ATPROTO_HANDLE_RESOLVER=https://bsky.social
