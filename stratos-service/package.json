{
  "name": "@northskysocial/stratos-service",
  "version": "0.1.0",
  "description": "Standalone Stratos private namespace service for ATProtocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "stratos": "./dist/bin/stratos.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "format": "prettier --write .",
    "lint": "eslint --ext .ts .",
    "codegen": "lex gen-server ./src/lexicon ../lexicons --yes",
    "generate:version": "tsx scripts/generate-version.ts"
  },
  "dependencies": {
    "@atcute/atproto": "^3.1.10",
    "@atcute/car": "^5.1.1",
    "@atcute/cbor": "^2.3.2",
    "@atcute/cid": "^2.4.1",
    "@atcute/client": "^4.2.1",
    "@atcute/lexicons": "^1.2.9",
    "@atcute/mst": "^0.1.2",
    "@atcute/repo": "^0.1.2",
    "@atcute/uint8array": "^1.1.1",
    "@atproto/api": "^0.18.20",
    "@atproto/aws": "^0.2.31",
    "@atproto/common": "^0.5.11",
    "@atproto/common-web": "^0.4.16",
    "@atproto/crypto": "^0.4.5",
    "@atproto/did": "^0.3.0",
    "@atproto/identity": "^0.4.11",
    "@atproto/jwk-jose": "^0.1.11",
    "@atproto/lex-cbor": "^0.0.9",
    "@atproto/lex-data": "^0.0.9",
    "@atproto/lexicon": "^0.6.1",
    "@atproto/oauth-client-node": "^0.3.16",
    "@atproto/oauth-provider": "^0.15.9",
    "@atproto/syntax": "^0.4.3",
    "@atproto/xrpc-server": "^0.10.12",
    "@ipld/dag-cbor": "^9.2.5",
    "@libsql/client": "^0.17.0",
    "@northskysocial/stratos-core": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "1.0.0-beta.18-7eb39f0",
    "express": "^5.2.1",
    "express-async-errors": "^3.1.1",
    "http-terminator": "^3.2.0",
    "ioredis": "^5.5.0",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "multiformats": "^13.4.2",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.8",
    "tsx": "^4.21.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@atproto/lex-cli": "^0.9.8",
    "@atcute/cbor": "^2.3.2",
    "@eslint/js": "^10.0.1",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.1",
    "@types/ws": "^8.18.1",
    "axios": "^1.14.0",
    "eslint": "^10.0.0",
    "fast-check": "^4.5.0",
    "globals": "^17.3.0",
    "testcontainers": "^11.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
