{
  "name": "@northskysocial/stratos-service",
  "version": "0.1.0",
  "description": "Standalone Stratos private namespace service for ATProtocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "stratos": "./dist/bin/stratos.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "format": "prettier --write .",
    "lint": "eslint --ext .ts src",
    "codegen": "lex gen-server ../lexicons --out ./src/lexicon"
  },
  "dependencies": {
    "@northskysocial/stratos-core": "workspace:*",
    "@atproto/api": "^0.18.20",
    "@atproto/aws": "^0.2.31",
    "@atproto/common": "^0.5.11",
    "@atproto/common-web": "^0.4.16",
    "@atproto/crypto": "^0.4.5",
    "@atproto/did": "^0.3.0",
    "@atproto/identity": "^0.4.11",
    "@atproto/jwk-jose": "^0.1.11",
    "@atproto/lex-cbor": "^0.0.9",
    "@atproto/lex-data": "^0.0.9",
    "@atproto/lexicon": "^0.6.1",
    "@atproto/oauth-client-node": "^0.3.16",
    "@atproto/oauth-provider": "^0.15.9",
    "@atproto/repo": "^0.8.12",
    "@atproto/syntax": "^0.4.3",
    "@atproto/xrpc-server": "^0.10.12",
    "@ipld/dag-cbor": "^9.2.5",
    "@libsql/client": "^0.17.0",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-async-errors": "^3.1.1",
    "http-terminator": "^3.2.0",
    "jose": "^6.1.3",
    "multiformats": "^13.4.2",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@atproto/lex-cli": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.1",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT"
}
