# Test E2E Configuration
# Copy to .env and adjust values as needed

# PDS hostname (without protocol) - used for URL and handle construction
PDS_HOST=pds.example.com

# PDS admin password for account creation
PDS_ADMIN_PASSWORD=your-admin-password

# Stratos service URL
STRATOS_URL=http://localhost:3100
STRATOS_PORT=3100

# Ngrok configuration
USE_NGROK=true
NGROK_AUTHTOKEN=your-ngrok-authtoken

# OAuth client credentials (optional — issuer is discovered dynamically from user's PDS)
# STRATOS_OAUTH_CLIENT_ID=
# STRATOS_OAUTH_CLIENT_SECRET=

# Enable OAuth enrollment routes
USE_OAUTH=true

# Dev mode: allows Bearer DID auth without DPoP (for test scripts)
STRATOS_DEV_MODE=true

# Allow anyone to enrol
STRATOS_ENROLLMENT_MODE=open

# Storage backend: "sqlite" (default) or "postgres"
# When "postgres", also run: docker compose -f docker-compose.test.yml -f docker-compose.postgres.yml up -d --build
# STORAGE_BACKEND=postgres
