# Test E2E Configuration
# Copy to .env and adjust values as needed

# PDS hostname (without protocol) - used for URL and handle construction
PDS_HOST=pds.example.com

# PDS admin password for account creation
PDS_ADMIN_PASSWORD=your-admin-password

# Stratos service URL
STRATOS_URL=http://localhost:3100
STRATOS_PORT=3100

# Ngrok configuration
USE_NGROK=true
NGROK_AUTHTOKEN=your-ngrok-authtoken
