docs/
*.md
!README.md

# Docker files
Dockerfile
docker-compose*.yml
.dockerignore

# Environment files (use docker-compose environment instead)
.env
.env.*
!.env.example

# macOS
.DS_Store
*.swp
*.swo

# IDE
.idea/
*.iml

# Temporary files
tmp/
temp/
