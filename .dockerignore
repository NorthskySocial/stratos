# Dependencies
node_modules/
.pnpm-store/

# Build outputs (rebuilt in container)
dist/
*.js
*.d.ts
*.js.map

# Development
.git/
.github/
.vscode/
*.log
*.local

# Test files
coverage/
.nyc_output/
