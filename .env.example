# Stratos Service Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Service DID - unique identifier for this Stratos instance
# Generate using: did:web:your-domain.com or did:plc:...
STRATOS_SERVICE_DID=did:web:stratos.example.com

# Public URL where this service is accessible
STRATOS_PUBLIC_URL=https://stratos.example.com

# Allowed domains for boundary validation (comma-separated)
# Records can only use these domains in their boundaries
STRATOS_ALLOWED_DOMAINS=example.com,internal.example.com

# =============================================================================
# ENROLLMENT CONFIGURATION
# =============================================================================

# Enrollment mode: 'open' or 'allowlist'
# - open: anyone can enroll
# - allowlist: only allowed DIDs or PDS endpoints can enroll
STRATOS_ENROLLMENT_MODE=allowlist

# Allowed DIDs (comma-separated) - only used when ENROLLMENT_MODE=allowlist
# Example: did:plc:abc123,did:plc:xyz789
STRATOS_ALLOWED_DIDS=

# Allowed PDS endpoints (comma-separated) - only used when ENROLLMENT_MODE=allowlist
# Users from these PDS instances can enroll
# Example: https://bsky.social,https://pds.example.com
STRATOS_ALLOWED_PDS_ENDPOINTS=

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Blob storage type: 'local' or 's3'
STRATOS_BLOB_STORAGE=local

# Data directory (inside container, mounted as volume)
# STRATOS_DATA_DIR=/app/data

# S3 Configuration (only required if STRATOS_BLOB_STORAGE=s3)
# STRATOS_S3_BUCKET=stratos-blobs
# STRATOS_S3_REGION=us-east-1
# STRATOS_S3_ENDPOINT=http://minio:9000
# STRATOS_S3_ACCESS_KEY=minioadmin
# STRATOS_S3_SECRET_KEY=minioadmin

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Service port (default: 3100)
STRATOS_PORT=3100

# Service fragment for DID document (default: atproto_pns)
STRATOS_SERVICE_FRAGMENT=atproto_pns

# Record retention in days (default: 30)
STRATOS_RETENTION_DAYS=30

# PLC directory URL (default: https://plc.directory)
STRATOS_PLC_URL=https://plc.directory

# Signing key in hex format (generated if not provided)
# Generate using: openssl rand -hex 32
STRATOS_SIGNING_KEY_HEX=

# =============================================================================
# OAUTH CONFIGURATION (Optional)
# =============================================================================

# OAuth issuer URL
STRATOS_OAUTH_ISSUER=

# OAuth client credentials
STRATOS_OAUTH_CLIENT_ID=
STRATOS_OAUTH_CLIENT_SECRET=

# =============================================================================
# LOGGING
# =============================================================================

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info
