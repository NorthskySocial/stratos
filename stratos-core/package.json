{
  "name": "@northskysocial/stratos-core",
  "version": "0.1.0",
  "description": "Shared library for Stratos private namespace service",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./atproto": {
      "types": "./src/atproto/index.ts",
      "import": "./src/atproto/index.ts"
    },
    "./validation": {
      "types": "./src/validation/index.ts",
      "import": "./src/validation/index.ts"
    },
    "./db": {
      "types": "./src/db/index.ts",
      "import": "./src/db/index.ts"
    },
    "./db/pg": {
      "types": "./src/db/pg.ts",
      "import": "./src/db/pg.ts"
    },
    "./tests": {
      "types": "./tests/utils/index.ts",
      "import": "./tests/utils/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "format": "prettier --write .",
    "lint": "eslint --ext .ts ."
  },
  "dependencies": {
    "@atcute/atproto": "^3.1.10",
    "@atcute/car": "^5.1.1",
    "@atcute/cbor": "^2.3.2",
    "@atcute/cid": "^2.4.1",
    "@atcute/client": "^4.2.1",
    "@atcute/mst": "^0.1.2",
    "@atcute/uint8array": "^1.1.1",
    "@atproto/common-web": "^0.4.16",
    "@atproto/lex-cbor": "^0.0.9",
    "@atproto/lex-data": "^0.0.9",
    "@atproto/lexicon": "^0.6.1",
    "@atproto/syntax": "^0.4.3",
    "@libsql/client": "^0.17.0",
    "drizzle-orm": "1.0.0-beta.18-7eb39f0",
    "multiformats": "^13.4.2",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.5.0",
    "globals": "^17.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT"
}
